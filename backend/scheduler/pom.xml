<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.graphpilot</groupId>
        <artifactId>backend</artifactId>
        <version>0.1.0-SNAPSHOT</version>
    </parent>

    <artifactId>scheduler</artifactId>
    <packaging>jar</packaging>
    <name>GraphPilot Scheduler</name>
    <description>Task scheduling and DAG coordination. Triggers workflow runs, manages task dependencies, handles retries.</description>

    <dependencies>
        <!-- 共享层 -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>domain</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Application 层（内置于 scheduler） -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>scheduler-application</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>application-shared</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Persistence adapter -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-persistence-memory</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-persistence-mybatis</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Worker adapters -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-worker</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-worker-http</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- Spring Boot -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
