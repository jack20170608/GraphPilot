<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/xsd/maven-4.0.0.xsd https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.graphpilot</groupId>
        <artifactId>spring-boot</artifactId>
        <version>${revision}</version>
    </parent>

    <artifactId>worker</artifactId>
    <packaging>jar</packaging>
    <name>GraphPilot Worker</name>
    <description>Task execution worker. Receives tasks from scheduler and executes them using registered handlers (shell, mock).</description>

    <dependencies>
        <!-- Java Core -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>scheduler-application</artifactId>
        </dependency>

        <!-- Adapters -->
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-worker</artifactId>
        </dependency>
        <dependency>
            <groupId>com.graphpilot</groupId>
            <artifactId>adapter-worker-http</artifactId>
        </dependency>

        <!-- Spring Boot -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>