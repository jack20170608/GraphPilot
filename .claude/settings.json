{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git push origin *)",
      "Bash(mvn -f backend\\pom.xml validate*)",
      "Bash(mvn -f backend\\pom.xml compile*)",
      "Bash(mvn -f backend\\pom.xml test*)",
      "Bash(mvn -f backend\\pom.xml verify*)",
      "Bash(mvn -f backend\\pom.xml -pl *)",
      "Bash(java -version*)",
      "Bash(javac -version*)",
      "Bash(mvn -version*)",
      "Bash(node --version*)",
      "Bash(npm --version*)",
      "Bash(pnpm --version*)",
      "Bash(corepack --version*)",
      "Bash(npm install*)",
      "Bash(npm run build*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(pnpm install*)",
      "Bash(pnpm build*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(docker compose -f infra/docker-compose.yml ps*)",
      "Bash(docker compose -f infra/docker-compose.yml logs*)",
      "Bash(docker compose -f infra/docker-compose.yml config*)",
      "Bash(docker compose -f infra/docker-compose.yml up*)",
      "Bash(docker compose -f infra/docker-compose.yml down*)"
    ],
    "ask": [
      "Bash(git push --tags*)",
      "Bash(git tag*)",
      "Bash(docker compose -f infra/docker-compose.yml down -v*)",
      "Bash(docker compose -f infra/docker-compose.yml rm*)",
      "Bash(docker compose -f infra/docker-compose.yml pull*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /s *)",
      "Bash(rmdir /s *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -xfd*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git rebase -i*)",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)",
      "Bash(docker compose -f infra/docker-compose.yml down --volumes*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)"
    ],
    "defaultMode": "default"
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "The user has authorized Claude Code to push committed changes from this GraphPilot repository to configured remotes for automation, including direct pushes to origin/main when Claude has just created and verified the commit.",
      "Allow git push commands for this repository, while still respecting explicit deny rules such as force-push bans."
    ]
  }
}
