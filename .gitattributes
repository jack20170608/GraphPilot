# Normalize text files to LF in the repository.
* text=auto eol=lf

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts keep LF.
*.sh text eol=lf

# Source files
*.java text diff=java
*.kt text
*.kts text
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text
*.xml text
*.yml text
*.yaml text
*.css text
*.scss text
*.html text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.gz binary
